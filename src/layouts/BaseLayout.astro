---
import revealScript from "../scripts/reveal.js?url";
import formsScript from "../scripts/forms.js?url";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  ogType?: string;
  robots?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title = "Kitstation | Agencia de Marketing Digital y Desarrollo Web en Peru",
  description = "Creamos paginas web, campanas en Google Ads y Meta Ads, automatizaciones de WhatsApp y sistemas CRM para empresas en Peru.",
  image = "/images/og-kitstation.jpg",
  imageAlt = "Portada de Kitstation con servicios de marketing digital y desarrollo web",
  ogType = "website",
  robots = "index,follow",
  structuredData
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(image, Astro.site).toString();
const structuredDataItems = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#0553f1" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32.png" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700&family=Montserrat:wght@400;500;600&family=Poppins:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="KitStation" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={imageAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{title}</title>
    {structuredDataItems.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
  </head>
  <body>
    <slot />
    <script type="module" src={revealScript}></script>
    <script type="module" src={formsScript}></script>
  </body>
</html>
