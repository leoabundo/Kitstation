---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

interface Props {
  pageTitle: string;
  metaDescription: string;
  title: string;
  titleHtml?: string;
  subtitle?: string;
  accent: string;
  panelColor: string;
  videoSrc?: string;
  videoFit?: string;
  videoPadding?: string;
  contentWidth?: string;
  titleWidth?: string;
  titleSize?: string;
  titleMobileSize?: string;
  formName?: string;
}

const {
  pageTitle,
  metaDescription,
  title,
  titleHtml = "",
  subtitle = "",
  accent,
  panelColor,
  videoSrc = "",
  videoFit = "cover",
  videoPadding = "0",
  contentWidth = "450px",
  titleWidth = "100%",
  titleSize = "clamp(1.9rem, 2.7vw, 2.9rem)",
  titleMobileSize = "clamp(1.1rem, 5.4vw, 1.9rem)",
  formName = title
} = Astro.props;
---

<BaseLayout title={pageTitle} description={metaDescription}>
  <main
    class="service-form-page"
    style={`--service-accent:${accent}; --service-panel:${panelColor}; --service-video-fit:${videoFit}; --service-video-padding:${videoPadding};`}
  >
    <section class="service-form-page__split">
      <div class="service-form-page__left">
        <div
          class="service-form-page__content"
          style={`--service-content-width:${contentWidth}; --service-title-size:${titleSize}; --service-title-mobile-size:${titleMobileSize};`}
        >
          {titleHtml ? <h1 style={`--service-title-width:${titleWidth};`} set:html={titleHtml}></h1> : <h1 style={`--service-title-width:${titleWidth};`}>{title}</h1>}
          {subtitle && <p class="service-form-page__subtitle">{subtitle}</p>}

          <form class="service-form-page__form" method="POST" action="/api/enviar-formulario.php" data-mail-form>
            <input type="hidden" name="formulario" value={formName} />
            <input type="hidden" name="pagina_origen" value="" />
            <input class="form-honeypot" type="text" name="website" autocomplete="off" tabindex="-1" aria-hidden="true" />
            <input type="text" name="company" placeholder="Nombre de Empresa" required />
            <input type="email" name="email" placeholder="Correo" required />
            <input type="tel" name="phone" placeholder="Celular" required />
            <textarea name="message" placeholder="Mensaje" required></textarea>
            <button type="submit">ENVIAR</button>
            <p class="form-feedback" role="status" aria-live="polite"></p>
          </form>

          <p class="service-form-page__privacy">
            Al avanzar, aceptas las <a href="/politicas-y-privacidad/">Politica de privacidad</a>
          </p>
        </div>
      </div>

      <div class="service-form-page__right">
        <div class="service-form-page__video-slot" aria-hidden={videoSrc ? undefined : "true"}>
          {videoSrc && (
            <video class="service-form-page__video" autoplay muted playsinline loop preload="metadata">
              <source src={videoSrc} type="video/mp4" />
            </video>
          )}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .service-form-page {
    min-height: 100vh;
    background: #000;
  }

  .service-form-page__split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 100vh;
  }

  .service-form-page__left {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #000;
    padding: 48px 32px;
  }

  .service-form-page__content {
    width: min(100%, var(--service-content-width));
    text-align: center;
    color: #fff;
  }

  .service-form-page__content h1 {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: min(100%, var(--service-title-width));
    margin-inline: auto;
    font-size: var(--service-title-size);
    font-weight: 500;
    line-height: 1.18;
    letter-spacing: -0.04em;
  }

  :global(.service-form-page__title-line) {
    display: block;
    width: max-content;
    max-width: 100%;
    margin-inline: auto;
    white-space: nowrap;
    text-align: center;
  }

  .service-form-page__subtitle {
    margin: 34px 0 20px;
    color: rgba(255, 255, 255, 0.92);
    font-size: 1rem;
    line-height: 1.5;
  }

  .service-form-page__form {
    display: grid;
    gap: 12px;
    margin-top: 28px;
  }

  .service-form-page__form input,
  .service-form-page__form textarea {
    width: 100%;
    border: 0;
    border-radius: 6px;
    background: #fff;
    color: #111;
    padding: 0 16px;
    font-size: 0.98rem;
    outline: none;
  }

  .service-form-page__form input {
    height: 46px;
  }

  .service-form-page__form textarea {
    min-height: 120px;
    padding-top: 14px;
    resize: vertical;
  }

  .service-form-page__form button {
    height: 46px;
    border: 0;
    border-radius: 6px;
    background: #3325ff;
    color: #fff;
    font-size: 0.96rem;
    font-weight: 700;
    cursor: pointer;
  }

  .service-form-page__privacy {
    margin: 18px 0 0;
    color: rgba(255, 255, 255, 0.86);
    font-size: 0.92rem;
  }

  .service-form-page__privacy a {
    color: #2382ff;
  }

  .service-form-page__right {
    min-height: 100vh;
    background: var(--service-panel);
  }

  .service-form-page__video-slot {
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    padding: var(--service-video-padding);
  }

  .service-form-page__video {
    width: 100%;
    height: 100%;
    object-fit: var(--service-video-fit);
    display: block;
  }

  @media (max-width: 900px) {
    .service-form-page__split {
      grid-template-columns: 1fr;
    }

    .service-form-page__left {
      min-height: 100vh;
      padding: 40px 24px;
    }

    .service-form-page__right {
      display: none;
    }

    .service-form-page__content {
      width: min(100%, 440px);
    }

    .service-form-page__content h1 {
      font-size: var(--service-title-mobile-size);
      line-height: 1.16;
      letter-spacing: -0.03em;
    }
  }
</style>
