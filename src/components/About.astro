---

<section class="about" id="soluciones">
  <div class="container">
    <Reveal class="solutions-strip" delay={0}>
      <h2>Soluciones especificas<br />para tu empresa.</h2>

      <div class="solutions-slider" data-topic-slider>
        <button class="solutions-slider__arrow solutions-slider__arrow--prev" type="button" aria-label="Tema anterior" data-topic-prev>
          <svg viewBox="0 0 16 16" aria-hidden="true" focusable="false">
            <path
              fill-rule="evenodd"
              d="M12 8a.5.5 0 0 1-.5.5H5.707l2.147 2.146a.5.5 0 0 1-.708.708l-3-3a.5.5 0 0 1 0-.708l3-3a.5.5 0 1 1 .708.708L5.707 7.5H11.5a.5.5 0 0 1 .5.5"
            />
          </svg>
        </button>

        <div class="solutions-slider__viewport">
          <div class="solutions-slider__track" data-topic-track>
            {solutionTopics.map((topic, index) => (
              <button
                class="solutions-topic"
                type="button"
                data-topic-item
                data-topic-index={index}
                aria-pressed="false"
              >
                <span class="solutions-topic__icon" data-icon={topic.icon}>
                  <img src={`/icons/solutions/${topic.icon}.svg`} alt="" aria-hidden="true" loading="lazy" />
                </span>
                <span class="solutions-topic__label">{topic.label}</span>
              </button>
            ))}
          </div>
        </div>

        <button class="solutions-slider__arrow solutions-slider__arrow--next" type="button" aria-label="Tema siguiente" data-topic-next>
          <svg viewBox="0 0 16 16" aria-hidden="true" focusable="false">
            <path
              fill-rule="evenodd"
              d="M4 8a.5.5 0 0 1 .5-.5h5.793L8.146 5.354a.5.5 0 1 1 .708-.708l3 3a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708-.708L10.293 8.5H4.5A.5.5 0 0 1 4 8"
            />
          </svg>
        </button>
      </div>

      <div class="solutions-showcase" data-topic-panels>
        {solutionPanels.map((panel, index) => (
          <article class="solutions-panel" data-topic-panel data-topic-index={index}>
            <picture>
              <source media="(max-width: 768px)" srcset={panel.mobileImage} />
              <img src={panel.image} alt={panel.alt} loading="lazy" />
            </picture>
          </article>
        ))}
      </div>
    </Reveal>
  </div>
</section>

<section class="service-hub" id="servicios-hub">
  <div class="container">
    <Reveal class="service-hub__intro" delay={0}>
      <h2>Los servicios que necesitas<br />en un solo lugar</h2>
    </Reveal>

    <Reveal class="service-hub__board" delay={40}>
      {serviceHubCards.map((card, index) => (
        <input
          class="service-hub__toggle"
          type="radio"
          name="service-hub-slide"
          id={card.key}
          checked={index === 0}
        />
      ))}

      <div class="service-hub__chrome">
        <span></span>
        <span></span>
      </div>

      <div class="service-hub__sidebar" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </div>

      <div class="service-hub__grid"></div>

      <div class="service-hub__lines" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
        <span></span>
      </div>

      {serviceHubCards.filter((card) => card.className).map((card) => (
        <article class={card.className}>
          <label class="hub-card__link ripple-image" for={card.key} aria-label={`Ver ${card.title}`}>
            <div class="hub-card__media">
              <img src={card.image} alt={card.alt} loading="lazy" />
            </div>
          </label>
        </article>
      ))}
    </Reveal>

    <div class="service-hub__slides">
      {serviceHubCards
        .filter((card) => card.key !== "hub-default")
        .map((card) => (
          <article class={`service-slide service-slide--${card.key.replace("hub-", "")}`}>
            <label class="service-slide__back" for="hub-default">
              <span aria-hidden="true">←</span> Atras
            </label>

            <div class="service-slide__copy">
              <h3>{card.title}</h3>
              <p>{card.description}</p>
            </div>

            <div class={`service-slide__media${card.video ? "" : " service-slide__media--static"}`}>
              {card.video ? (
                <video autoplay muted playsinline loop preload="metadata">
                  <source src={card.video} type="video/mp4" />
                </video>
              ) : (
                <img src={card.image} alt={card.alt} loading="lazy" />
              )}
            </div>
          </article>
        ))}
    </div>

    <div class="service-hub__actions">
      <a class="button button--ghost service-hub__button" href="https://kitstation.pe/empezar-con-kit/">Empezar ahora</a>
    </div>
  </div>
</section>

<section class="performance-panel" id="rendimiento">
  <div class="container">
    <div class="performance-panel__top reveal reveal-up" data-reveal="up" data-delay="0">
      <h2>Mejora el <span>rendimiento</span><br />y <span>logística</span> de tu negocio</h2>
      <a class="performance-panel__cta" href="https://kitstation.pe/empezar-con-kit/">Empezar ahora</a>
    </div>

    <div class="performance-panel__grid">
      {performanceCards.map((card, index) => (
        <article class="performance-card reveal reveal-up" data-reveal="up" data-delay={index * 70}>
          <div class="performance-card__icon" data-icon={card.icon}>
            {card.icon === "handshake" && (
              <svg viewBox="0 0 74.93 61.67" aria-hidden="true">
                <path d="M56.42,0l-6.38,6.38c-.32-.04-.64-.07-.96-.1-2.28-.92-6.35-1.58-11.12,2.09l-.11.1-1.56,1.57c-5.89-4-10.58-1.53-11.89-.67l-5.87-5.87L0,22.02l7.02,7.02c.06,3.14,1.17,6.37,3.35,9.63.9,1.34,1.94,2.58,3.07,3.73,1.45,1.47,2.91,2.91,4.37,4.37-1.58,2.3-.9,4.2.74,5.92,1.71,1.78,3.28,1.99,5.6,1.32.02,0,.04,0,.06.02,1.66,2.49,3.19,3.69,4.84,3.82.69.67,1.36,1.34,2.05,2,2.04,1.97,5.16,2.41,7.62,1,1.06-.61,1.24-1.11,1.79-1.98,4.16,3.5,6.95,3.56,10.22-1.35.01-.02.03-.03.06-.02,2.32.67,3.89.46,5.6-1.32,1.74-1.81,2.4-3.83.46-6.31-.01-.02-.51-.67-.49-.67,1.39.04,2.48-.84,3.09-1.62,1.61-2.08,1.51-4.27-.22-6.43.76-.76,1.52-1.51,2.27-2.27,1.13-1.15,2.18-2.38,3.07-3.73,2.17-3.26,3.29-6.48,3.35-9.63l7.02-7.02L56.42,0ZM14.56,39.7c-2.13-2.25-3.73-4.73-4.43-7.55-.15-.63-.26-1.27-.33-1.93-.05-.54-.07-1.09-.05-1.66l-7.11-7.12,15.3-15.3,4.9,4.9.32.32-.02.05,2.37.2.15-.38c.93-.64,4.81-2.79,9.99,1.16l6.85,6.88c.34.35.53.81.53,1.3s-.19.95-.54,1.3l-.45.45c-.72.71-1.88.71-2.6,0l-7.01-7.04-1.7,1.19,1.89,2.22.82.83c-.81.81-1.61,1.61-2.42,2.42-.2.2-.32.42-.37.64-.04.04-.08.08-.12.12-4.71,4.72-9.44,9.42-14.14,14.15-.94.95-1.56,1.9-1.86,2.85ZM37.27,58.79c-.54.51-1.1.83-1.91.77-1.12-.09-1.9-.94-2.44-1.48-.33-.33-.66-.66-.99-.98.78-.42,1.6-1,2.48-1.74.55.87.73,1.37,1.79,1.98.48.27.98.48,1.49.61-.09.35-.23.65-.43.84ZM47.37,57.85c-1.05,1.24-2.25,1.34-3.79-.08-.24-.22-.47-.45-.71-.67.33-.22.66-.47.95-.76.88-.85,1.75-1.71,2.62-2.56.09.09.19.19.28.28,1.44,1.45,1.64,2.62.64,3.79ZM54.69,54.02c-1.06,1.45-2.69,1.48-4.14.03-.72-.72-1.44-1.44-2.17-2.16,1.19-1.16,2.39-2.32,3.57-3.49.67.67,1.34,1.34,2.01,2.01,1.29,1.3,1.51,2.52.72,3.61ZM57.66,45.44c-.54,1.35-2.14,1.99-3.41,1.29-.13-.07-.24-.15-.36-.23,1.15-1.14,2.28-2.28,3.43-3.43.49.65.75,1.38.35,2.37ZM65.17,25.06c.02.56,0,1.12-.05,1.66-.06.66-.17,1.31-.33,1.93-.7,2.83-2.31,5.32-4.45,7.58-2.91,3.06-5.95,5.98-8.94,8.97-3.13,3.13-6.25,6.28-9.41,9.38-.54.53-1.32,1.39-2.44,1.48-.81.06-1.37-.25-1.91-.77-.49-.46-.65-1.62-.46-2.35.2-.79.9-1.5,1.51-2.1