---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "./Header.astro";
import MarqueeBar from "./MarqueeBar.astro";
import Footer from "./Footer.astro";
import WhatsAppButton from "./WhatsAppButton.astro";
import "../styles/global.css";
import type { ServicePageConfig } from "../data/servicePages";

interface Props {
  service: ServicePageConfig;
  relatedServices: ServicePageConfig[];
}

const { service, relatedServices } = Astro.props;
const whatsappHref = `https://wa.me/51901637020?text=${encodeURIComponent(
  `Hola, quiero informacion sobre ${service.shortName} para mi empresa.`
)}`;
const serviceUrl = new URL(service.href, Astro.site).toString();
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: service.title,
  description: service.metaDescription,
  url: serviceUrl,
  areaServed: {
    "@type": "Country",
    name: "Peru"
  },
  provider: {
    "@type": "Organization",
    name: "Kitstation",
    url: new URL("/", Astro.site).toString()
  }
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Inicio",
      item: new URL("/", Astro.site).toString()
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Servicios",
      item: new URL("/#servicios", Astro.site).toString()
    },
    {
      "@type": "ListItem",
      position: 3,
      name: service.shortName,
      item: serviceUrl
    }
  ]
};
---

<BaseLayout
  title={service.pageTitle}
  description={service.metaDescription}
  image={service.image}
  imageAlt={service.title}
  structuredData={[serviceSchema, breadcrumbSchema]}
>
  <Header />
  <MarqueeBar />
  <main class="seo-service-page">
    <section class="seo-service-page__hero" style={`--service-accent:${service.accent};`}>
      <div class="container">
        <nav class="seo-service-page__crumbs" aria-label="Breadcrumb">
          <a href="/">Inicio</a>
          <span>/</span>
          <a href="/#servicios">Servicios</a>
          <span>/</span>
          <span>{service.shortName}</span>
        </nav>

        <div class="seo-service-page__hero-grid">
          <div class="seo-service-page__copy">
            <p class="eyebrow">Servicio estrategico para empresas en Peru</p>
            <h1>{service.heading}</h1>
            <p class="seo-service-page__intro">{service.intro}</p>
            <p class="seo-service-page__summary">{service.summary}</p>

            <div class="seo-service-page__actions">
              <a class="button button--primary" href="/contactanos/">Cotizar servicio</a>
              <a class="button button--ghost" href={whatsappHref} target="_blank" rel="noreferrer">Hablar por WhatsApp</a>
            </div>
          </div>

          <aside class="seo-service-page__panel">
            <p class="seo-service-page__panel-title">Lo que resolvemos</p>
            <ul>
              {service.benefits.map((benefit) => (
                <li>{benefit}</li>
              ))}
            </ul>
          </aside>
        </div>
      </div>
    </section>

    <section class="seo-service-page__section">
      <div class="container">
        <div class="seo-service-page__section-copy">
          <p class="eyebrow">Beneficios</p>
          <h2>Una solucion pensada para vender con mas orden</h2>
        </div>

        <div class="seo-service-page__benefits">
          {service.benefits.map((benefit, index) => (
            <article class="seo-service-page__card">
              <span>0{index + 1}</span>
              <p>{benefit}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="seo-service-page__section seo-service-page__section--alt">
      <div class="container">
        <div class="seo-service-page__section-copy">
          <p class="eyebrow">Proceso de trabajo</p>
          <h2>Como trabajamos cada proyecto</h2>
        </div>

        <div class="seo-service-page__process">
          {service.process.map((step, index) => (
            <article class="seo-service-page__step">
              <p class="seo-service-page__step-number">Paso {index + 1}</p>
              <h3>{step.title}</h3>
              <p>{step.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="seo-service-page__section">
      <div class="container">
        <div class="seo-service-page__section-copy">
          <p class="eyebrow">Enlaces internos</p>
          <h2>Servicios relacionados de Kitstation</h2>
        </div>

        <div class="seo-service-page__related">
          {relatedServices.map((item) => (
            <a class="seo-service-page__related-link" href={item.href}>
              <strong>{item.shortName}</strong>
              <span>{item.title}</span>
            </a>
          ))}
        </div>

        <div class="seo-service-page__bottom-actions">
          <a class="button button--primary" href="/">Volver a la home</a>
          <a class="button button--dark" href="/contactanos/">Ir a contacto</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <WhatsAppButton />
</BaseLayout>

<style>
  .seo-service-page {
    background: #ffffff;
  }

  .seo-service-page__hero {
    padding: 72px 0 56px;
    background:
      radial-gradient(circle at top left, color-mix(in srgb, var(--service-accent) 16%, white) 0%, rgba(255, 255, 255, 0) 34%),
      linear-gradient(180deg, #f6f9ff 0%, #ffffff 100%);
  }

  .seo-service-page__crumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 24px;
    color: #5f6674;
    font-size: 0.92rem;
  }

  .seo-service-page__hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
    gap: 28px;
    align-items: start;
  }

  .seo-service-page__copy h1 {
    margin: 0 0 18px;
    max-width: 980px;
    color: #0d162f;
    font-size: clamp(2.5rem, 5vw, 4.6rem);
    font-weight: 600;
    line-height: 0.96;
    letter-spacing: -0.06em;
  }

  .seo-service-page__intro,
  .seo-service-page__summary {
    max-width: 820px;
    color: #445067;
    font-size: 1.04rem;
  }

  .seo-service-page__intro {
    margin: 0 0 12px;
  }

  .seo-service-page__summary {
    margin: 0;
  }

  .seo-service-page__actions,
  .seo-service-page__bottom-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 28px;
  }

  .seo-service-page__panel {
    padding: 26px 24px;
    border: 1px solid rgba(13, 22, 47, 0.1);
    border-radius: 24px;
    background: #ffffff;
    box-shadow: 0 20px 48px rgba(9, 18, 37, 0.08);
  }

  .seo-service-page__panel-title {
    margin: 0 0 16px;
    color: #0d162f;
    font-weight: 700;
  }

  .seo-service-page__panel ul {
    margin: 0;
    padding-left: 20px;
    color: #445067;
  }

  .seo-service-page__panel li + li {
    margin-top: 12px;
  }

  .seo-service-page__section {
    padding: 28px 0 82px;
  }

  .seo-service-page__section--alt {
    background: #f7f9fd;
  }

  .seo-service-page__section-copy {
    max-width: 860px;
    margin-bottom: 24px;
  }

  .seo-service-page__section-copy h2 {
    margin: 0;
    color: #0d162f;
    font-size: clamp(2rem, 3.8vw, 3.4rem);
    line-height: 0.98;
    letter-spacing: -0.05em;
  }

  .seo-service-page__benefits,
  .seo-service-page__process,
  .seo-service-page__related {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .seo-service-page__card,
  .seo-service-page__step,
  .seo-service-page__related-link {
    padding: 24px 22px;
    border: 1px solid rgba(13, 22, 47, 0.1);
    border-radius: 22px;
    background: #ffffff;
    color: #445067;
  }

  .seo-service-page__card span,
  .seo-service-page__step-number {
    display: inline-block;
    margin-bottom: 12px;
    color: var(--service-accent);
    font-size: 0.86rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .seo-service-page__card p,
  .seo-service-page__step p {
    margin: 0;
  }

  .seo-service-page__step h3,
  .seo-service-page__related-link strong {
    display: block;
    margin: 0 0 12px;
    color: #0d162f;
    font-size: 1.16rem;
  }

  .seo-service-page__related-link {
    transition: transform 0.22s ease, border-color 0.22s ease;
  }

  .seo-service-page__related-link:hover {
    transform: translateY(-3px);
    border-color: var(--service-accent);
  }

  .seo-service-page__related-link span {
    display: block;
    line-height: 1.5;
  }

  @media (max-width: 960px) {
    .seo-service-page__hero-grid,
    .seo-service-page__benefits,
    .seo-service-page__process,
    .seo-service-page__related {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .seo-service-page__hero {
      padding: 48px 0 42px;
    }

    .seo-service-page__section {
      padding: 18px 0 64px;
    }

    .seo-service-page__actions,
    .seo-service-page__bottom-actions {
      flex-direction: column;
    }
  }
</style>
