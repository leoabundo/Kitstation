<div class="animated-phone reveal reveal-right" data-reveal="right" data-delay="180">
  <div class="animated-phone__glow"></div>

  <video
    class="animated-phone__video animated-phone__video--desktop"
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
    aria-label="Video visual del hero de KitStation"
  >
    <source src="/videos/hero-phone.mp4" type="video/mp4" />
  </video>

  <video
    class="animated-phone__video animated-phone__video--mobile"
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
    aria-label="Video visual del hero de KitStation para movil"
  >
    <source src="https://kitstation.pe/wp-content/uploads/2025/06/phone-kit-ver.mp4" type="video/mp4" />
  </video>
</div>
